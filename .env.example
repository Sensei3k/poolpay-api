# Copy this file to .env and fill in your real credentials.
# Never commit .env to git.

# --- Required ---

# Found in your Green API dashboard under "Instances"
GREEN_API_INSTANCE_ID=your_instance_id_here

# The API token shown next to your instance
GREEN_API_TOKEN=your_api_token_here

# --- Optional ---

# Directory where receipt files are saved during OCR (default: OS temp dir)
# RECEIPT_DOWNLOAD_DIR=/tmp/receipt_engine

# Log verbosity: debug | info | warn | error (default: info)
# RUST_LOG=info

# --- Google Sheets integration (Phase 9) ---

# Path to the service account JSON key file downloaded from the GCP console.
# NEVER commit this file — it is a credential. It is excluded via .gitignore.
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=/path/to/service-account.json

# The spreadsheet ID from the Google Sheets URL:
#   https://docs.google.com/spreadsheets/d/<THIS_PART>/edit
GOOGLE_SPREADSHEET_ID=your_spreadsheet_id_here
